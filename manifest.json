{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.1.0",
  "description": "__MSG_shortDesc__",
  "default_locale": "en",
  "icons": {
    "16": "src/assets/16x16.png",
    "32": "src/assets/32x32.png",
    "48": "src/assets/48x48.png",
    "64": "src/assets/64x64.png",
    "96": "src/assets/128x128-96x96.png",
    "128": "src/assets/128x128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/assets/16x16.png",
      "32": "src/assets/32x32.png",
      "48": "src/assets/48x48.png",
      "64": "src/assets/64x64.png",
      "96": "src/assets/128x128-96x96.png",
      "128": "src/assets/128x128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "sandbox": {
    "pages": ["src/sandbox/dwg-sandbox.html"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "permissions": []
}
