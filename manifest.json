{
  "manifest_version": 3,
  "name": "DXF File Viewer",
  "version": "1.0.0",
  "description": "Open .dxf drawings instantly in your browser. Layer toggles, pan & zoom, dark theme. No upload, no install.",
  "icons": {
    "16": "src/assets/16x16.png",
    "32": "src/assets/32x32.png",
    "48": "src/assets/48x48.png",
    "64": "src/assets/64x64.png",
    "128": "src/assets/128x128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/assets/16x16.png",
      "32": "src/assets/32x32.png",
      "48": "src/assets/48x48.png",
      "64": "src/assets/64x64.png",
      "128": "src/assets/128x128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": []
}
